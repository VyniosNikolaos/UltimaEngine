# Ignore everything by default
*

# Allow essential directories
!*/

# Allow source files
!*.c
!*.h
!*.cpp
!*.hpp

# Allow CMake files
!CMakeLists.txt
!*.cmake
!cmake/
!cmake/**

# Allow project files
!LICENSE
!README.md
!.gitignore

# Allow specific project directories
!UltimaCore/
!UltimaCore/**
!UltimaTempTest/
!UltimaTempTest/**

# Explicitly ignore IDE files
.idea/
.vs/
*.suo
*.user
*.sln.docstates

# Explicitly ignore build directories
cmake-build-*/
build/
out/
Debug/
Release/

# Explicitly ignore Unreal Engine assets
*.fbx
*.uasset
*.umap

# Explicitly ignore compilation artifacts
*.o
*.obj
*.exe
*.out
*.a
*.so
*.dylib
*.dll

# Explicitly ignore OS files
.DS_Store
Thumbs.db

# Explicitly ignore screenshots and temporary files
*.png
*.jpg
*.jpeg
